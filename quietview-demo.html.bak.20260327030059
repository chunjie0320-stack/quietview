<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QuietView</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Noto Sans SC",-apple-system,BlinkMacSystemFont,"PingFang SC","Helvetica Neue",sans-serif;background:#FAF8F5;color:#2D2826;height:100vh;overflow:hidden;display:flex;flex-direction:column}

/* topbar */
#topbar{position:fixed;top:0;left:0;right:0;height:52px;background:#FFFFFF;border-bottom:1px solid #EDE8E2;display:flex;align-items:center;padding:0 24px;z-index:100;gap:0}
.topbar-logo{font-family:"Noto Sans SC",sans-serif;font-size:20px;font-weight:600;color:#2D2826;letter-spacing:.02em;white-space:nowrap;margin-right:40px}
.topbar-logo span{color:#8B7355}
.topbar-tabs{display:flex;align-items:center;gap:32px;flex:1}
.tab-btn{font-size:18px;font-weight:400;color:#7A7268;cursor:pointer;user-select:none;padding:0 2px;height:52px;display:flex;align-items:center;position:relative;border:none;background:transparent;transition:color .15s;font-family:"Noto Sans SC",sans-serif}
.tab-btn::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:#8B7355;opacity:0;transition:opacity .15s}
.tab-btn:hover{color:#2D2826}
.tab-btn.active{color:#2D2826;font-weight:500}
.tab-btn.active::after{opacity:1}
#topbar-date{font-size:17px;color:#B8B0A4;font-weight:300;white-space:nowrap;margin-left:auto}

/* layout */
#app-body{display:flex;overflow:hidden;padding-top:52px;height:100vh;align-items:stretch}

/* sidebar */
#sidebar{width:240px;min-width:240px;background:#FEFEFE;border-right:1px solid #EDE8E2;display:flex;flex-direction:column;overflow-y:auto;z-index:10;flex-shrink:0;align-self:stretch}
nav{padding:12px 0;flex:1}
.nav-l2{display:flex;align-items:center;justify-content:space-between;padding:7px 20px;font-size:17px;color:#5A5248;cursor:pointer;user-select:none;transition:background .15s,color .15s}
.nav-l2:hover{background:#F8F5F1;color:#2D2826}
.nav-l2.active,.nav-l2.selected{background:#F5F0EA;color:#6B5840;font-weight:500;border-left:3px solid #8B7355;padding-left:17px}
.nav-l2 .chevron{font-size:14px;transition:transform .2s;color:#ccc;flex-shrink:0}
.nav-l2.open .chevron{transform:rotate(90deg)}
.nav-l2-children{overflow:hidden;max-height:0;transition:max-height .2s ease}
.nav-l2-children.open{max-height:500px}
.nav-l3{display:flex;align-items:center;padding:6px 20px 6px 36px;font-size:16px;color:#9A9188;cursor:pointer;user-select:none;transition:background .15s,color .15s}
.nav-l3:hover{background:#F8F5F1;color:#2D2826}
.nav-l3.active{background:#F5F0EA;color:#6B5840;font-weight:500;border-left:3px solid #8B7355;padding-left:33px}
.nav-l3::before{content:'·';font-size:18px;color:#C8C0B4;margin-right:8px;flex-shrink:0;line-height:1}
.nav-l3.active::before{color:#8B7355}

/* main */
#main{flex:1;overflow-y:auto;padding:32px 36px;position:relative;min-height:0;align-self:stretch}
.content-panel{display:none}
.content-panel.active{display:block;animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.page-header{margin-bottom:32px}
.page-header h1{font-family:"Noto Sans SC",sans-serif;font-size:32px;font-weight:300;color:#2D2826;margin-bottom:12px;line-height:1.3;letter-spacing:.01em}
.page-header .sub{font-size:17px;color:#9A9188;margin-bottom:16px;font-weight:300}
.page-header-divider{height:1px;background:#F0EDE8;margin-bottom:0}

/* cards */
.card{background:#FFFFFF;border-radius:12px;padding:24px;box-shadow:0 2px 8px rgba(139,115,85,.06),0 0 0 1px rgba(139,115,85,.08);margin-bottom:20px;transition:transform .2s,box-shadow .2s}
.card:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(139,115,85,.08),0 0 0 1px rgba(139,115,85,.1)}

/* charts */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.chart-full{grid-column:1/-1}
.chart-box{background:#FFFFFF;border-radius:12px;padding:20px;box-shadow:0 2px 8px rgba(139,115,85,.06),0 0 0 1px rgba(139,115,85,.08);transition:transform .2s,box-shadow .2s}
.chart-box:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(139,115,85,.08),0 0 0 1px rgba(139,115,85,.1)}
.chart-box-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.chart-box-title-wrap{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap}
.chart-box-title{font-size:18px;font-weight:500;color:#2D2826;font-family:"Noto Sans SC",sans-serif}
.chart-price{font-size:24px;font-weight:500;color:#E05E5E;font-family:"Noto Sans SC",sans-serif;line-height:1}
.chart-price.up{color:#4DAA6A}
.chart-change-tag{font-size:15px;padding:2px 8px;border-radius:4px;background:rgba(224,94,94,.1);color:#E05E5E;font-weight:400}
.chart-change-tag.up{background:rgba(77,170,106,.1);color:#4DAA6A}
.chart-period-btns{display:flex;gap:4px}
.period-btn{padding:4px 12px;font-size:15px;border:none;border-radius:100px;background:#F5F0EA;color:#8B7355;cursor:pointer;transition:all .15s;font-family:"Noto Sans SC",sans-serif;font-weight:400}
.period-btn:hover{background:#EDE8E2;color:#5A4535}
.period-btn.active{background:#2D2826;color:#fff}
.chart-dom{width:100%;height:240px}
.vix-header-wrap{display:flex;align-items:center;justify-content:space-between;width:100%}
.vix-current-val{font-size:17px;color:#8B7355;font-weight:500;background:#F5F0EA;padding:2px 10px;border-radius:100px}

/* two-col */
.two-col{display:grid;grid-template-columns:1fr 1px 1fr;gap:0}
.two-col-divider{background:#F0EDE8;align-self:stretch}
.two-col > div:last-child{padding-left:24px}
.two-col > div:first-child{padding-right:24px}
.col-title{font-size:16px;font-weight:400;color:#B0A898;letter-spacing:.08em;text-transform:uppercase;margin-bottom:20px;padding-bottom:10px;border-bottom:1px solid #F0EDE8;display:flex;align-items:center;gap:6px}
.col-count-badge{font-size:15px;color:#B0A898;font-weight:300}

/* timeline */
.timeline{position:relative;padding-left:20px}
.timeline::before{content:'';position:absolute;left:5px;top:8px;bottom:8px;width:1px;background:#E8E3DC}
.tl-item{position:relative;margin-bottom:20px}
.tl-item:last-child{margin-bottom:0}
.tl-dot{position:absolute;left:-19px;top:7px;width:6px;height:6px;border-radius:50%;background:#C8C0B4;border:2px solid #FEFEFE;transition:width .15s,height .15s,left .15s,top .15s}
.tl-item:hover .tl-dot{width:8px;height:8px;left:-20px;top:6px}
.tl-item:first-child .tl-dot{background:#8B7355;border-color:#FEFEFE}
.tl-time{font-size:15px;color:#B8B0A4;margin-bottom:4px;font-weight:300}
.tl-tag{display:inline-block;font-size:14px;padding:2px 8px;border-radius:100px;background:#F0EDE8;color:#8B7355;font-weight:400;margin-bottom:6px;letter-spacing:.02em}
.tl-title{font-size:18px;font-weight:500;color:#2D2826;margin-bottom:5px;line-height:1.55}
.tl-body{font-size:17px;color:#7A7268;line-height:1.7;font-weight:300}
.tl-person{font-size:17px;font-weight:500;color:#2D2826;margin-bottom:5px}

/* miao bubble */
.miao-bubble{margin-top:12px;background:#FEFCF8;border:1px solid #EDE0D0;border-radius:10px;padding:10px 14px 10px 40px;font-size:16.5px;color:#5A5248;line-height:1.65;position:relative;font-family:"Noto Sans SC",-apple-system,BlinkMacSystemFont,"PingFang SC","Helvetica Neue",sans-serif}
.miao-bubble::before{content:'🐾';position:absolute;left:12px;top:10px;font-size:19px;line-height:1}
.miao-bubble-label{display:block;font-size:15px;font-weight:500;color:#8B7355;margin-bottom:5px;letter-spacing:.02em}

/* miao card */
.miao-card{background:#FEFCF8;border-radius:10px;padding:14px 16px;font-size:17px;color:#5A5248;line-height:1.7;border-left:3px solid transparent;border-image:linear-gradient(to bottom,#8B7355,transparent) 1;margin-bottom:16px;font-weight:300;font-family:"Noto Sans SC",-apple-system,BlinkMacSystemFont,"PingFang SC","Helvetica Neue",sans-serif}
.miao-card:last-child{margin-bottom:0}
.miao-card-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.miao-card-time{font-size:15px;font-weight:500;color:#8B7355}
.miao-card-date{font-size:14px;color:#C0B8AE;background:#F5F0EA;padding:1px 7px;border-radius:100px}
/* miao date group */
.miao-date-group{margin-bottom:32px}
.miao-date-label{font-size:16px;font-weight:500;color:#B0A898;letter-spacing:.06em;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid #F0EDE8}
/* source link */
.tl-source{display:inline-block;margin-top:7px;font-size:15px;color:#8B7355;text-decoration:none;border-bottom:1px solid rgba(139,115,85,.25);transition:border-color .15s,color .15s}
.tl-source:hover{color:#5A4535;border-bottom-color:#5A4535}
/* 两列各自可滚动 */
.two-col > div:not(.two-col-divider){display:flex;flex-direction:column;overflow:hidden;max-height:520px}
.two-col > div:not(.two-col-divider) .timeline{overflow-y:auto;flex:1;padding-right:6px}
.two-col > div:not(.two-col-divider) .timeline::-webkit-scrollbar{width:3px}
.two-col > div:not(.two-col-divider) .timeline::-webkit-scrollbar-track{background:transparent}
.two-col > div:not(.two-col-divider) .timeline::-webkit-scrollbar-thumb{background:#DDD8D0;border-radius:2px}
</style>
</head>
