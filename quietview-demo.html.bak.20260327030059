  function renderMiaoNotice(notice) {
    if (!notice) return;
    // 优先使用带日期后缀的 id，回退到通用 #miao-notice（20260325 panel）
    var el = document.querySelector('#miao-notice-' + dateStr) || document.querySelector('#miao-notice');
    if (!el) return;
    el.innerHTML = '<span class="miao-bubble-label">' + escHtml(notice.label) + '</span>' + notice.content;
  }

  // XSS 防护：HTML 转义
  function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function escAttr(str) {
    if (!str) return '';
    // 只允许 http/https 开头，防止 javascript: 注入
    var s = String(str).trim();
    if (!/^https?:\/\//i.test(s)) return '#';
    return s.replace(/"/g,'&quot;');
  }
})();
</script>
