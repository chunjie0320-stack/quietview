#!/usr/bin/env python3
"""
喵子告知 自动更新脚本
每天 06:00 / 10:00 / 14:00 / 18:00 / 22:00 触发
读取 quietview-demo.html 中的行业资讯+行业声音内容
调用 AI 生成喵子告知，替换 #miao-notice 区块
"""

import re
import sys
import subprocess
import json
from datetime import datetime
from html.parser import HTMLParser
import os

HTML_PATH = "/root/.openclaw/workspace/quietview-demo.html"
REPO_DIR  = "/root/.openclaw/workspace"

# ── 1. 提取资讯和声音文本 ─────────────────────────────────────────────────────

class TextExtractor(HTMLParser):
    def __init__(self):
        super().__init__()
        self.capture = False
        self.skip_tags = {'script', 'style'}
        self.skip_depth = 0
        self.texts = []
        self._current = []

    def handle_starttag(self, tag, attrs):
        if tag in self.skip_tags:
            self.skip_depth += 1
        attrs_dict = dict(attrs)
        cls = attrs_dict.get('class', '')
        aid = attrs_dict.get('id', '')
        if any(c in cls for c in ['tl-title','tl-body','tl-person','tl-tag','tl-time','tl-source']) \
                or 'miao-bubble' in cls:
            self.capture = True
            self._current = []

    def handle_endtag(self, tag):
        if tag in self.skip_tags:
            self.skip_depth -= 1
        if tag == 'div' and self._current:
            t = ' '.join(self._current).strip()
            if t and len(t) > 2:
                self.texts.append(t)
            self._current = []
            self.capture = False

    def handle_data(self, data):
        if self.skip_depth > 0:
            return
        if self.capture:
            d = data.strip()
            if d:
                self._current.append(d)


def extract_content(html_path):
    with open(html_path, encoding='utf-8') as f:
        html = f.read()

    # 只提取 panel-daily-brief 区域
    m = re.search(r'id="panel-daily-brief[^"]*"(.*?)</div>\s*</div>\s*</div>\s*<!-- /main', html, re.DOTALL)
    if not m:
        # fallback: 抓两列内容
        m = re.search(r'class="two-col"(.*?)class="two-col-divider"', html, re.DOTALL)
    section = m.group(1) if m else html

    # 提取资讯
    news_items = re.findall(
        r'<div class="tl-title">([^<]+)</div>\s*<div class="tl-body">([^<]+)</div>',
        section
    )
    # 提取声音
    voice_items = re.findall(
        r'<div class="tl-tag">([^<]+)</div>\s*<div class="tl-title">([^<]+)</div>\s*<div class="tl-body">([^<]+)</div>',
        section
    )

    news_text = "\n".join([f"· {t}：{b}" for t, b in news_items]) if news_items else "（暂无资讯）"
    voice_text = "\n".join([f"· [{src}] {t}：{b}" for src, t, b in voice_items]) if voice_items else "（暂无声音）"
    return news_text, voice_text


# ── 2. 调用 AI 生成喵子告知 ──────────────────────────────────────────────────

def generate_notice(news_text, voice_text, slot_label):
    prompt = f"""你是喵子，一只资深投资视角+产品思维的三花猫AI助手，文风简练有料。

现在是{slot_label}，请基于以下行业资讯和行业声音，写一段「喵子告知」：
- 整理核心信息，找出关键信号
- 给出喵子自己的判断和点评
- 风格：一针见血，大白话优先，100-200字，不超过3段

【行业资讯】
{news_text}

【行业声音】
{voice_text}

直接输出告知内容，不要任何前缀或解释。"""

    # 用 catclaw proxy API（OpenAI 兼容接口）
    try:
        import urllib.request
        # 从 openclaw.json 读取配置
        config_path = os.path.expanduser("~/.openclaw/openclaw.json")
        with open(config_path, encoding='utf-8') as f:
            cfg = json.load(f)
        provider = cfg.get('models', {}).get('providers', {}).get('kubeplex-maas', {})
        base_url = provider.get('baseUrl', 'https://mmc.sankuai.com/openclaw/v1')
        api_key  = provider.get('apiKey', 'catpaw')
        model_id = provider.get('models', [{}])[0].get('id', 'catclaw-proxy-model')
        extra_headers = provider.get('headers', {})

        payload = json.dumps({
            "model": model_id,
            "messages": [{"role": "user", "content": prompt}],
            "max_tokens": 600,
            "stream": False
        }).encode('utf-8')

        headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        }
        headers.update(extra_headers)

        req = urllib.request.Request(
            f"{base_url}/chat/completions",
            data=payload,
            headers=headers,
            method="POST"
        )
        with urllib.request.urlopen(req, timeout=90) as resp:
            raw = resp.read().decode('utf-8', errors='ignore')

        # 判断是否为 SSE 流式响应（data: 开头）
        if raw.strip().startswith('data:'):
            # 解析 SSE 格式，拼接所有 content delta
            full_content = []
            for line in raw.split('\n'):
                line = line.strip()
                if not line.startswith('data:'):
                    continue
                # 去掉 "data:" 或 "data:data:" 前缀
                json_str = re.sub(r'^data:data:', '', line)
                json_str = re.sub(r'^data:', '', json_str).strip()
                if json_str in ('[DONE]', ''):
                    continue
                try:
                    chunk = json.loads(json_str)
                    delta = chunk.get('choices', [{}])[0].get('delta', {})
                    if delta.get('content'):
                        full_content.append(delta['content'])
                except Exception:
                    continue
            content = ''.join(full_content).strip()
        else:
            # 非流式，直接解析
            data = json.loads(raw)
            content = data['choices'][0]['message']['content'].strip()

        if content:
            return content
    except Exception as e:
        print(f"  [generate_notice] catclaw proxy error: {e}", file=sys.stderr)
        import traceback
        traceback.print_exc(file=sys.stderr)

    return f"（喵子暂时无法生成告知：AI接口连接失败）"


# ── 3. 替换 HTML 中的 miao-notice ────────────────────────────────────────────

def update_html(html_path, notice_text, slot_label):
    with open(html_path, encoding='utf-8') as f:
        html = f.read()

    # 转义 HTML 特殊字符（保留<br>换行）
    def escape(s):
        return s.replace('&', '&amp;').replace('<', '&lt;').replace('>', '&gt;').replace('\n\n', '<br><br>').replace('\n', '<br>')

    new_block = f"""<div id="miao-notice" class="miao-bubble" style="margin-bottom:24px;border-radius:12px;">
          <span class="miao-bubble-label">🐱 喵子告知 · {slot_label}</span>
          {escape(notice_text)}
        </div>"""

    # 替换 id="miao-notice" 整个 div 块
    pattern = r'<div id="miao-notice"[^>]*>.*?</div>'
    new_html = re.sub(pattern, new_block, html, flags=re.DOTALL)

    if new_html == html:
        print("⚠️  miao-notice block not found, appending...")
        # fallback: 在 two-col 前插入
        new_html = html.replace(
            '<div class="two-col">',
            new_block + '\n        <div class="two-col">',
            1
        )

    with open(html_path, 'w', encoding='utf-8') as f:
        f.write(new_html)
    print(f"✅ HTML updated: {slot_label}")


# ── 4. div 自查 ──────────────────────────────────────────────────────────────

def verify_divs(html_path):
    class C(HTMLParser):
        def __init__(self): super().__init__(); self.d = 0
        def handle_starttag(self, t, a):
            if t == 'div': self.d += 1
        def handle_endtag(self, t):
            if t == 'div': self.d -= 1
    with open(html_path) as f:
        h = f.read()
    p = C(); p.feed(h)
    if p.d != 0:
        raise ValueError(f"div depth={p.d}, not 0! Aborting push.")
    print(f"✅ div depth OK (0)")


# ── 5. git commit + push ──────────────────────────────────────────────────────

def git_push(slot_label):
    subprocess.run(['git', 'add', 'quietview-demo.html'], cwd=REPO_DIR, check=True)
    subprocess.run(
        ['git', 'commit', '-m', f'auto: 喵子告知更新 {slot_label}'],
        cwd=REPO_DIR, check=True
    )
    subprocess.run(['git', 'push'], cwd=REPO_DIR, check=True)
    print(f"✅ pushed: 喵子告知 {slot_label}")


# ── main ──────────────────────────────────────────────────────────────────────

def main():
    now = datetime.now()
    slot_label = now.strftime("%Y.%m.%d %H:%M")

    print(f"[{slot_label}] 喵子告知更新开始...")

    try:
        news_text, voice_text = extract_content(HTML_PATH)
        print(f"  资讯条数: {news_text.count('·')}, 声音条数: {voice_text.count('·')}")

        notice = generate_notice(news_text, voice_text, slot_label)
        print(f"  生成内容: {notice[:60]}...")

        update_html(HTML_PATH, notice, slot_label)
        verify_divs(HTML_PATH)
        git_push(slot_label)

        print(f"[{slot_label}] ✅ 完成")

    except Exception as e:
        print(f"[{slot_label}] ❌ 失败: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
